<div class="form-container">
    <% if (error) { %>
        <p class="error-msg"><%= error %></p>
    <% } %>

    <% if (success) { %>
        <p class="success-msg"><%= success %></p>
    <% } %>

    <form class="form" id="calcul-form" method="POST" action="/calcul">
        <div class="section-form">
            <label for="programme">Programme</label>
            <select id="programme" name="programme">
                <option value="prime" <%= formData.programme === 'prime' ? 'selected' : '' %>>Nombres premiers</option>
                <option value="monte_carlo" <%= formData.programme === 'monte_carlo' ? 'selected' : '' %>>Monte-Carlo (pi)</option>
            </select>
        </div>

        <div class="section-form">
            <label for="valeur">
                <span id="valeur-label">Valeur de calcul</span>
            </label>
            <input type="number" id="valeur" name="valeur" value="<%= formData.valeur %>" required>
        </div>

        <div class="section-form">
            <label for="nb_process">Nombre de processus MPI</label>
            <input type="number" id="nb_process" name="nb_process" value="<%= formData.nb_process %>" required>
        </div>

        <input type="submit" class="form-btn" value="Lancer le calcul">
        <input type="reset" class="form-btn" value="Réinitialiser">
    </form>

    <div id="processing-indicator" class="processing-indicator" aria-live="polite">
        <span class="spinner" aria-hidden="true"></span>
        <span>Votre calcul est sous traitement...</span>
    </div>
</div>

<script src="/static/js/calcul.js" defer></script>
